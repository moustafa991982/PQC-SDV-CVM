# Local Azure state — never commit
scripts/.state
scripts/.known_hosts

# Generated cert chains - these are demo PKI; regenerated by build_chains.sh
certs/out/

# Local SSH keys generated by 03_bootstrap_cvm.sh
*.pem
*.key
!certs/openssl.cnf.tmpl

# QEMU artifacts
qemu-client/vcu.qcow2
qemu-client/seed.iso
qemu-client/noble-server-cloudimg-*.img

# Measurement run data (large pcaps)
measure/runs/*/hs.pcap
measure/runs/*/hs.log
# but keep the metrics.json files
!measure/runs/*/metrics.json

# Python bytecode
__pycache__/
*.pyc

# Editor / OS noise
.vscode/
.idea/
.DS_Store
*.swp
*~
